              <ExportPanel
                events={events.filter((e) => e.selected)}
                courseName={courseName}
                timezone={timezone}
                onReset={handleReset}
                onBack={() => setStep("review")}
              />
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </main>
  );
}
